            {
              "name": "workflow",
              "label": "工作流",
              "type": "text",
              "placeholder": "chat",
              "defaultValue": "chat"
            }
          ]
        }
      ]
    },
    {
      "id": "file",
      "title": "文件管理",
      "apis": [
        {
          "id": "file-upload",
          "method": "POST",
          "path": "/api/file/upload",
          "title": "上传文件",
          "description": "上传文件到服务器"
        },
        {
          "id": "file-get",
          "method": "GET",
          "path": "/api/file/:id",
          "title": "获取文件",
          "description": "通过文件ID获取文件内容",
          "pathParams": {
            "id": {
              "label": "文件ID",
              "placeholder": "file_id"
            }
          },
          "queryParams": [
            {
              "name": "download",
              "label": "下载模式",
              "type": "select",
              "options": [
                {
                  "value": "false",
                  "label": "预览"
                },
                {
                  "value": "true",
                  "label": "下载"
                }
              ],
              "defaultValue": "false"
            }
          ]
        },
        {
          "id": "file-delete",
          "method": "DELETE",
          "path": "/api/file/:id",
          "title": "删除文件",
          "description": "删除已上传的文件",
          "pathParams": {
            "id": {
              "label": "文件ID",
              "placeholder": "file_id"
            }
          }
        },
        {
          "id": "file-list",
          "method": "GET",
          "path": "/api/files",
          "title": "文件列表",
          "description": "获取所有已上传的文件列表"
        },
        {
          "id": "file-download",
          "method": "GET",
          "path": "/api/file/download/:id",
          "title": "下载文件",
          "description": "强制下载已上传文件（Yunzai）",
          "pathParams": {
            "id": {
              "label": "文件ID",
              "placeholder": "file_id"
            }
          }
        },
        {
          "id": "file-preview",
          "method": "GET",
