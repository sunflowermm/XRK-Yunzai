{
  "apiGroups": [
    {
      "id": "core",
      "title": "核心系统",
      "apis": [
        {
          "id": "system-status",
          "method": "GET",
          "path": "/api/status",
          "title": "系统状态",
          "description": "获取系统运行状态、机器人信息和适配器列表"
        },
        {
          "id": "system-status-detail",
          "method": "GET",
          "path": "/api/system/status",
          "title": "系统状态详情",
          "description": "获取系统状态详细信息"
        },
        {
          "id": "system-overview",
          "method": "GET",
          "path": "/api/system/overview",
          "title": "系统概览",
          "description": "获取仪表盘面板、工作流与网络统计数据",
          "queryParams": [
            {
              "name": "withHistory",
              "label": "包含历史网络数据",
              "type": "select",
              "options": [
                {
                  "value": "0",
                  "label": "否"
                },
                {
                  "value": "1",
                  "label": "是"
                }
              ],
              "defaultValue": "1"
            }
          ]
        },
        {
          "id": "system-config",
          "method": "GET",
          "path": "/api/config",
          "title": "系统配置",
          "description": "获取系统配置信息"
        },
        {
          "id": "health-check",
          "method": "GET",
          "path": "/api/health",
          "title": "健康检查",
          "description": "检查系统各服务的健康状态"
        }
      ]
    },
    {
      "id": "bot",
      "title": "机器人管理",
      "apis": [
        {
          "id": "bot-list",
          "method": "GET",
          "path": "/api/bots",
          "title": "机器人列表",
          "description": "获取所有已连接的机器人",
          "queryParams": [
            {
              "name": "includeDevices",
              "label": "包含设备",
              "type": "select",
              "options": [
                {
                  "value": "0",
                  "label": "否"
                },
                {
                  "value": "1",
                  "label": "是"
                }
              ],
              "defaultValue": "0"
            }
          ]
        },
        {
          "id": "bot-friends",
          "method": "GET",
          "path": "/api/bot/:uin/friends",
          "title": "好友列表",
          "description": "获取指定机器人的好友列表",
          "pathParams": {
            "uin": {
              "label": "机器人UIN",
              "placeholder": "123456789"
            }
          }
        },
        {
          "id": "bot-groups",
          "method": "GET",
          "path": "/api/bot/:uin/groups",
          "title": "群组列表",
          "description": "获取指定机器人的群组列表",
          "pathParams": {
            "uin": {
              "label": "机器人UIN",
              "placeholder": "123456789"
            }
          }
        },
        {
          "id": "bot-control",
          "method": "POST",
          "path": "/api/bot/:uin/control",
          "title": "控制机器人",
          "description": "执行机器人控制命令",
          "pathParams": {
            "uin": {
              "label": "机器人UIN",
              "placeholder": "123456789"
            }
          },
          "bodyParams": [
            {
              "name": "action",
              "label": "操作类型",
              "type": "select",
              "required": true,
              "options": [
                {
                  "value": "shutdown",
                  "label": "关机"
                },
                {
                  "value": "startup",
                  "label": "开机"
                }
              ]
            }
          ]
        },
        {
          "id": "message-send",
          "method": "POST",
          "path": "/api/message/send",
          "title": "发送消息",
          "description": "向好友或群组发送文本或图片（图片需先上传）",
          "bodyParams": [
            {
              "name": "bot_id",
              "label": "机器人ID",
              "type": "text",
              "placeholder": "留空使用默认机器人"
            },
            {
              "name": "type",
              "label": "消息类型",
              "type": "select",
              "required": true,
              "options": [
                {
                  "value": "private",
                  "label": "私聊"
                },
                {
                  "value": "group",
                  "label": "群聊"
                }
              ]
            },
            {
              "name": "target_id",
              "label": "目标ID",
              "type": "text",
              "required": true,
              "placeholder": "好友QQ或群号"
            },
            {
              "name": "message",
              "label": "消息内容",
              "type": "textarea",
              "placeholder": "文本内容（发图时可留空）"
            },
            {
              "name": "file_id",
              "label": "图片文件ID",
              "type": "text",
              "placeholder": "先调用 /api/file/upload 获取 file_id"
            },
            {
              "name": "file_ids",
              "label": "多图文件ID",
              "type": "json",
              "placeholder": "[\"file_id_1\", \"file_id_2\"]"
            }
          ]
        }
      ]
    },
    {
      "id": "stdin",
      "title": "标准输入",
      "apis": [
        {
          "id": "stdin-command",
          "method": "POST",
          "path": "/api/stdin/command",
          "title": "发送命令",
          "description": "通过标准输入发送命令到机器人系统",
          "bodyParams": [
            {
              "name": "command",
              "label": "命令内容",
              "type": "textarea",
              "required": true,
              "placeholder": "输入命令"
            },
            {
              "name": "user_info",
              "label": "用户信息",
              "type": "json",
              "placeholder": "{\"user_id\": \"web_api_user\"}"
            },
            {
              "name": "json",
              "label": "返回JSON结果",
              "type": "select",
              "options": [
                {
                  "value": "true",
                  "label": "是（按插件输出结构化返回）"
                },
                {
                  "value": "false",
                  "label": "否（仅返回基础执行结果）"
                }
              ],
              "defaultValue": "true"
            }
          ]
        },
        {
          "id": "stdin-event",
          "method": "POST",
          "path": "/api/stdin/event",
          "title": "触发事件",
          "description": "创建自定义事件触发插件响应",
          "bodyParams": [
            {
              "name": "event_type",
              "label": "事件类型",
              "type": "text",
              "required": true,
              "placeholder": "message"
            },
            {
              "name": "content",
              "label": "事件内容",
              "type": "json",
              "required": true,
              "placeholder": "{\"message\": \"测试\"}"
            }
          ]
        },
        {
          "id": "stdin-status",
          "method": "GET",
          "path": "/api/stdin/status",
          "title": "Stdin状态",
          "description": "获取标准输入处理器的状态信息"
        }
      ]
    },
    {
      "id": "ai",
      "title": "AI 功能",
      "apis": [
        {
          "id": "ai-stream",
          "method": "GET",
          "path": "/api/ai/stream",
          "title": "AI 流式对话",
          "description": "通过 SSE 获取 AI 流式回复",
          "queryParams": [
            {
              "name": "prompt",
              "label": "提示词",
              "type": "text",
              "required": true,
              "placeholder": "你好"
            },
            {
              "name": "workflow",
              "label": "工作流名称",
              "type": "text",
              "placeholder": "chat",
              "defaultValue": "chat"
            },
            {
              "name": "persona",
              "label": "人设",
              "type": "text",
              "placeholder": "AI 人设设置"
            }
          ]
        },
        {
          "id": "ai-models",
          "method": "GET",
          "path": "/api/ai/models",
          "title": "AI 模型列表",
          "description": "获取可用的 AI 模型和工作流列表（支持 format=openai 参数返回 OpenAI 兼容格式）",
          "queryParams": [
            {
              "name": "format",
              "label": "返回格式",
              "type": "select",
              "options": [
                {
                  "value": "",
                  "label": "详细格式（默认）"
                },
                {
                  "value": "openai",
                  "label": "OpenAI 兼容格式"
                }
              ]
            }
          ]
        },
        {
          "id": "v3-models",
          "method": "GET",
          "path": "/api/v3/models",
          "title": "OpenAI 模型列表",
          "description": "OpenAI 兼容的模型列表接口（与 /v3/chat/completions 搭配使用）"
        },
        {
          "id": "v3-chat-completions",
          "method": "POST",
          "path": "/api/v3/chat/completions",
          "title": "OpenAI 兼容接口",
          "description": "OpenAI Chat Completions（鉴权用 X-API-Key 请求头；model 为 LLM 提供商名）",
          "bodyParams": [
            {
              "name": "messages",
              "label": "消息列表",
              "type": "json",
              "required": true,
              "placeholder": "[{\"role\": \"user\", \"content\": \"你好\"}]"
            },
            {
              "name": "model",
              "label": "模型/提供商",
              "type": "text",
              "placeholder": "volcengine"
            },
            {
              "name": "stream",
              "label": "流式输出",
              "type": "select",
              "options": [
                {
                  "value": "false",
                  "label": "否"
                },
                {
                  "value": "true",
                  "label": "是"
                }
              ],
              "defaultValue": "false"
            }
          ]
        }
      ]
    },
    {
      "id": "config",
      "title": "配置管理",
      "apis": [
        {
          "id": "config-list",
          "method": "GET",
          "path": "/api/config/list",
          "title": "配置列表",
          "description": "获取所有配置文件列表"
        },
        {
          "id": "config-structure",
          "method": "GET",
          "path": "/api/config/:name/structure",
          "title": "配置结构",
          "description": "获取配置文件的 Schema 结构",
          "pathParams": {
            "name": {
              "label": "配置名称",
              "placeholder": "system"
            }
          }
        },
        {
          "id": "config-flat-structure",
          "method": "GET",
          "path": "/api/config/:name/flat-structure",
          "title": "扁平化结构",
          "description": "获取配置文件的扁平化 Schema 结构（Schema）",
          "pathParams": {
            "name": {
              "label": "配置名称",
              "placeholder": "system"
            }
          },
          "queryParams": [
            {
              "name": "path",
              "label": "配置路径",
              "type": "text",
              "placeholder": "log_level"
            }
          ]
        },
        {
          "id": "config-flat",
          "method": "GET",
          "path": "/api/config/:name/flat",
          "title": "扁平化数据",
          "description": "获取配置文件当前值的扁平化数据",
          "pathParams": {
            "name": {
              "label": "配置名称",
              "placeholder": "system"
            }
          },
          "queryParams": [
            {
              "name": "path",
              "label": "配置路径",
              "type": "text",
              "placeholder": "log_level"
            }
          ]
        },
        {
          "id": "config-read",
          "method": "GET",
          "path": "/api/config/:name/read",
          "title": "读取配置",
          "description": "读取指定配置文件（或子配置）的内容",
          "pathParams": {
            "name": {
              "label": "配置名称",
              "placeholder": "system"
            }
          },
          "queryParams": [
            {
              "name": "path",
              "label": "配置路径",
              "type": "text",
              "placeholder": "log_level"
            }
          ]
        },
        {
          "id": "config-write",
          "method": "POST",
          "path": "/api/config/:name/write",
          "title": "写入配置",
          "description": "写入配置到指定文件或子配置",
          "pathParams": {
            "name": {
              "label": "配置名称",
              "placeholder": "system"
            }
          },
          "bodyParams": [
            {
              "name": "data",
              "label": "配置数据",
              "type": "json",
              "required": true,
              "placeholder": "{\"log_level\": \"info\"}"
            },
            {
              "name": "path",
              "label": "配置路径",
              "type": "text",
              "placeholder": "log_level"
            },
            {
              "name": "backup",
              "label": "是否备份",
              "type": "select",
              "options": [
                {
                  "value": "true",
                  "label": "是"
                },
                {
                  "value": "false",
                  "label": "否"
                }
              ],
              "defaultValue": "true"
            }
          ]
        },
        {
          "id": "config-batch-set",
          "method": "POST",
          "path": "/api/config/:name/batch-set",
          "title": "批量设置",
          "description": "批量设置配置项（扁平化 path => value）",
          "pathParams": {
            "name": {
              "label": "配置名称",
              "placeholder": "system"
            }
          },
          "bodyParams": [
            {
              "name": "flat",
              "label": "扁平化数据",
              "type": "json",
              "required": true,
              "placeholder": "{\"log_level\": \"info\"}"
            },
            {
              "name": "path",
              "label": "（可选）子配置名称",
              "type": "text",
              "placeholder": "log"
            },
            {
              "name": "backup",
              "label": "是否备份",
              "type": "select",
              "options": [
                {
                  "value": "true",
                  "label": "是"
                },
                {
                  "value": "false",
                  "label": "否"
                }
              ],
              "defaultValue": "true"
            }
          ]
        },
        {
          "id": "config-validate",
          "method": "POST",
          "path": "/api/config/:name/validate",
          "title": "校验配置",
          "description": "根据 Schema 校验配置数据是否有效（不落盘）",
          "pathParams": {
            "name": {
              "label": "配置名称",
              "placeholder": "system"
            }
          },
          "bodyParams": [
            {
              "name": "data",
              "label": "待校验数据",
              "type": "json",
              "required": true,
              "placeholder": "{\"log_level\": \"debug\"}"
            }
          ]
        },
        {
          "id": "config-backup",
          "method": "POST",
          "path": "/api/config/:name/backup",
          "title": "备份配置文件",
          "description": "为指定配置生成一份备份文件",
          "pathParams": {
            "name": {
              "label": "配置名称",
              "placeholder": "system"
            }
          }
        },
        {
          "id": "config-reset",
          "method": "POST",
          "path": "/api/config/:name/reset",
          "title": "重置为默认值",
          "description": "将配置重置为默认值（可选是否备份）",
          "pathParams": {
            "name": {
              "label": "配置名称",
              "placeholder": "system"
            }
          },
          "bodyParams": [
            {
              "name": "backup",
              "label": "是否备份当前值",
              "type": "select",
              "options": [
                {
                  "value": "true",
                  "label": "是"
                },
                {
                  "value": "false",
                  "label": "否"
                }
              ],
              "defaultValue": "true"
            }
          ]
        },
        {
          "id": "config-clear-cache",
          "method": "POST",
          "path": "/api/config/clear-cache",
          "title": "清除配置缓存",
          "description": "清除所有配置文件在内存中的缓存"
        },
        {
          "id": "config-merge",
          "method": "POST",
          "path": "/api/config/:name/merge",
          "title": "合并配置",
          "description": "深度或浅层合并配置片段（Yunzai）",
          "pathParams": {
            "name": {
              "label": "配置名",
              "placeholder": "server"
            }
          },
          "bodyParams": [
            {
              "name": "data",
              "label": "合并数据",
              "type": "json",
              "required": true
            }
          ]
        },
        {
          "id": "config-delete-key",
          "method": "DELETE",
          "path": "/api/config/:name/delete",
          "title": "删除配置项",
          "description": "按 path 删除单个配置键（Yunzai）",
          "pathParams": {
            "name": {
              "label": "配置名",
              "placeholder": "server"
            }
          },
          "bodyParams": [
            {
              "name": "path",
              "label": "键路径",
              "type": "text",
              "required": true
            }
          ]
        },
        {
          "id": "config-array-append",
          "method": "POST",
          "path": "/api/config/:name/array/append",
          "title": "数组追加",
          "description": "向配置数组追加元素（Yunzai）",
          "pathParams": {
            "name": {
              "label": "配置名",
              "placeholder": "server"
            }
          },
          "bodyParams": [
            {
              "name": "path",
              "label": "数组路径",
              "type": "text",
              "required": true
            },
            {
              "name": "value",
              "label": "值",
              "type": "json",
              "required": true
            }
          ]
        },
        {
          "id": "config-array-remove",
          "method": "POST",
          "path": "/api/config/:name/array/remove",
          "title": "数组移除",
          "description": "从配置数组移除元素（Yunzai）",
          "pathParams": {
            "name": {
              "label": "配置名",
              "placeholder": "server"
            }
          },
          "bodyParams": [
            {
              "name": "path",
              "label": "数组路径",
              "type": "text",
              "required": true
            },
            {
              "name": "index",
              "label": "索引",
              "type": "number",
              "required": true
            }
          ]
        }
      ]
    },
    {
      "id": "device",
      "title": "设备管理",
      "apis": [
        {
          "id": "device-register",
