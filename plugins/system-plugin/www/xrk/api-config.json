            },
            {
              "name": "device_type",
              "label": "设备类型",
              "type": "text",
              "required": true,
              "placeholder": "sensor"
            },
            {
              "name": "device_name",
              "label": "设备名称",
              "type": "text",
              "placeholder": "温度传感器"
            },
            {
              "name": "capabilities",
              "label": "设备能力",
              "type": "json",
              "placeholder": "[\"temperature\"]"
            }
          ]
        },
        {
          "id": "device-list",
          "method": "GET",
          "path": "/api/devices",
          "title": "设备列表",
          "description": "获取所有注册的物联网设备"
        },
        {
          "id": "device-detail",
          "method": "GET",
          "path": "/api/device/:deviceId",
          "title": "设备详情",
          "description": "获取指定设备的详细信息",
          "pathParams": {
            "deviceId": {
              "label": "设备ID",
              "placeholder": "DEVICE_001"
            }
          }
        },
        {
          "id": "device-ai",
