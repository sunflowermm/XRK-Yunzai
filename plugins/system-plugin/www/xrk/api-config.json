              "options": [
                {
                  "value": "overwrite",
                  "label": "覆盖"
                },
                {
                  "value": "merge",
                  "label": "深度合并"
                },
                {
                  "value": "append",
                  "label": "追加数组"
                },
                {
                  "value": "update",
                  "label": "按 path 更新"
                }
              ],
              "defaultValue": "overwrite"
            },
            {
              "name": "path",
              "label": "（仅 update 时）目标路径",
              "type": "text",
              "placeholder": "apiGroups.0.title"
            },
            {
              "name": "backup",
              "label": "写入前备份原文件",
              "type": "select",
              "options": [
                {
                  "value": "true",
                  "label": "是"
                },
                {
                  "value": "false",
                  "label": "否"
                }
              ],
              "defaultValue": "true"
            }
          ]
        }
      ]
    }
