{
  "apiGroups": [
    {
      "id": "core",
      "title": "核心系统",
      "apis": [
        {
          "id": "system-status",
          "method": "GET",
          "path": "/api/status",
          "title": "系统状态",
          "description": "获取系统运行状态、机器人信息和适配器列表"
        },
        {
          "id": "system-status-detail",
          "method": "GET",
          "path": "/api/system/status",
          "title": "系统状态详情",
          "description": "获取系统状态详细信息"
        },
        {
          "id": "system-overview",
          "method": "GET",
          "path": "/api/system/overview",
          "title": "系统概览",
          "description": "获取仪表盘面板、工作流与网络统计数据",
          "queryParams": [
            {
              "name": "withHistory",
              "label": "包含历史网络数据",
              "type": "select",
              "options": [
                { "value": "0", "label": "否" },
                { "value": "1", "label": "是" }
              ],
              "defaultValue": "1"
            }
          ]
        },
        {
          "id": "system-config",
          "method": "GET",
          "path": "/api/config",
          "title": "系统配置",
          "description": "获取系统配置信息"
        },
        {
          "id": "health-check",
          "method": "GET",
          "path": "/api/health",
          "title": "健康检查",
          "description": "检查系统各服务的健康状态"
        }
      ]
    },
    {
      "id": "bot",
      "title": "机器人管理",
      "apis": [
        {
          "id": "bot-list",
          "method": "GET",
          "path": "/api/bots",
          "title": "机器人列表",
          "description": "获取所有已连接的机器人",
          "queryParams": [
            {
              "name": "includeDevices",
              "label": "包含设备",
              "type": "select",
              "options": [
                { "value": "0", "label": "否" },
                { "value": "1", "label": "是" }
              ],
              "defaultValue": "0"
            }
          ]
        },
        {
          "id": "bot-friends",
          "method": "GET",
          "path": "/api/bot/:uin/friends",
          "title": "好友列表",
          "description": "获取指定机器人的好友列表",
          "pathParams": {
            "uin": {
              "label": "机器人UIN",
              "placeholder": "123456789"
            }
          }
        },
        {
          "id": "bot-groups",
          "method": "GET",
          "path": "/api/bot/:uin/groups",
          "title": "群组列表",
          "description": "获取指定机器人的群组列表",
          "pathParams": {
            "uin": {
              "label": "机器人UIN",
              "placeholder": "123456789"
            }
          }
        },
        {
          "id": "bot-control",
          "method": "POST",
          "path": "/api/bot/:uin/control",
          "title": "控制机器人",
          "description": "执行机器人控制命令",
          "pathParams": {
            "uin": {
              "label": "机器人UIN",
              "placeholder": "123456789"
            }
          },
          "bodyParams": [
            {
              "name": "action",
              "label": "操作类型",
              "type": "select",
              "required": true,
              "options": [
                { "value": "shutdown", "label": "关机" },
                { "value": "startup", "label": "开机" }
              ]
            }
          ]
        },
        {
          "id": "message-send",
          "method": "POST",
          "path": "/api/message/send",
          "title": "发送消息",
          "description": "向好友或群组发送消息",
          "bodyParams": [
            {
              "name": "bot_id",
              "label": "机器人ID",
              "type": "text",
              "placeholder": "留空使用默认机器人"
            },
            {
              "name": "type",
              "label": "消息类型",
              "type": "select",
              "required": true,
              "options": [
                { "value": "private", "label": "私聊" },
                { "value": "group", "label": "群聊" }
              ]
            },
            {
              "name": "target_id",
              "label": "目标ID",
              "type": "text",
              "required": true,
              "placeholder": "好友QQ或群号"
            },
            {
              "name": "message",
              "label": "消息内容",
              "type": "textarea",
              "required": true,
              "placeholder": "输入消息内容"
            }
          ]
        }
      ]
    },
    {
      "id": "stdin",
      "title": "标准输入",
      "apis": [
        {
          "id": "stdin-command",
          "method": "POST",
          "path": "/api/stdin/command",
          "title": "发送命令",
          "description": "通过标准输入发送命令到机器人系统",
          "bodyParams": [
            {
              "name": "command",
              "label": "命令内容",
              "type": "textarea",
              "required": true,
              "placeholder": "输入命令"
            },
            {
              "name": "user_info",
              "label": "用户信息",
              "type": "json",
              "placeholder": "{\"user_id\": \"web_api_user\"}"
            },
            {
              "name": "json",
              "label": "返回JSON结果",
              "type": "select",
              "options": [
                { "value": "true", "label": "是（按插件输出结构化返回）" },
                { "value": "false", "label": "否（仅返回基础执行结果）" }
              ],
              "defaultValue": "true"
            }
          ]
        },
        {
          "id": "stdin-event",
          "method": "POST",
          "path": "/api/stdin/event",
          "title": "触发事件",
          "description": "创建自定义事件触发插件响应",
          "bodyParams": [
            {
              "name": "event_type",
              "label": "事件类型",
              "type": "text",
              "required": true,
              "placeholder": "message"
            },
            {
              "name": "content",
              "label": "事件内容",
              "type": "json",
              "required": true,
              "placeholder": "{\"message\": \"测试\"}"
            }
          ]
        },
        {
          "id": "stdin-status",
          "method": "GET",
          "path": "/api/stdin/status",
          "title": "Stdin状态",
          "description": "获取标准输入处理器的状态信息"
        }
      ]
    },
    {
      "id": "ai",
      "title": "AI 功能",
      "apis": [
        {
          "id": "ai-stream",
          "method": "GET",
          "path": "/api/ai/stream",
          "title": "AI 流式对话",
          "description": "通过 SSE 获取 AI 流式回复",
          "queryParams": [
            {
              "name": "prompt",
              "label": "提示词",
              "type": "text",
              "required": true,
              "placeholder": "你好"
            },
            {
              "name": "workflow",
              "label": "工作流名称",
              "type": "text",
              "placeholder": "chat",
              "defaultValue": "chat"
            },
            {
              "name": "persona",
              "label": "人设",
              "type": "text",
              "placeholder": "AI 人设设置"
            }
          ]
        },
        {
          "id": "ai-models",
          "method": "GET",
          "path": "/api/ai/models",
          "title": "AI 模型列表",
          "description": "获取可用的 AI 模型和工作流列表（支持 format=openai 参数返回 OpenAI 兼容格式）",
          "queryParams": [
            {
              "name": "format",
              "label": "返回格式",
              "type": "select",
              "options": [
                { "value": "", "label": "详细格式（默认）" },
                { "value": "openai", "label": "OpenAI 兼容格式" }
              ]
            }
          ]
        },
        {
          "id": "v3-models",
          "method": "GET",
          "path": "/api/v3/models",
          "title": "OpenAI 模型列表",
          "description": "OpenAI 兼容的模型列表接口（与 /api/v3/chat/completions 搭配使用）"
        },
        {
          "id": "v3-chat-completions",
          "method": "POST",
          "path": "/api/v3/chat/completions",
          "title": "OpenAI 兼容接口",
          "description": "OpenAI Chat Completions 兼容接口",
          "bodyParams": [
            {
              "name": "apiKey",
              "label": "访问密钥",
              "type": "password",
              "required": true,
              "placeholder": "访问密钥"
            },
            {
              "name": "messages",
              "label": "消息列表",
              "type": "json",
              "required": true,
              "placeholder": "[{\"role\": \"user\", \"content\": \"你好\"}]"
            },
            {
              "name": "model",
              "label": "模型/提供商",
              "type": "text",
              "placeholder": "volcengine"
            },
            {
              "name": "stream",
              "label": "流式输出",
              "type": "select",
              "options": [
                { "value": "false", "label": "否" },
                { "value": "true", "label": "是" }
              ],
              "defaultValue": "false"
            }
          ]
        }
      ]
    },
    {
      "id": "config",
      "title": "配置管理",
      "apis": [
        {
          "id": "config-list",
          "method": "GET",
          "path": "/api/config/list",
          "title": "配置列表",
          "description": "获取所有配置文件列表"
        },
        {
          "id": "config-structure",
          "method": "GET",
          "path": "/api/config/:name/structure",
          "title": "配置结构",
          "description": "获取配置文件的 Schema 结构",
          "pathParams": {
            "name": {
              "label": "配置名称",
              "placeholder": "bot"
            }
          }
        },
        {
          "id": "config-flat-structure",
          "method": "GET",
          "path": "/api/config/:name/flat-structure",
          "title": "扁平化结构",
          "description": "获取配置文件的扁平化 Schema 结构",
          "pathParams": {
            "name": {
              "label": "配置名称",
              "placeholder": "bot"
            }
          },
          "queryParams": [
            {
              "name": "path",
              "label": "配置路径",
              "type": "text",
              "placeholder": "log_level"
            }
          ]
        },
        {
          "id": "config-read",
          "method": "GET",
          "path": "/api/config/:name/read",
          "title": "读取配置",
          "description": "读取指定配置文件的内容",
          "pathParams": {
            "name": {
              "label": "配置名称",
              "placeholder": "bot"
            }
          },
          "queryParams": [
            {
              "name": "path",
              "label": "配置路径",
              "type": "text",
              "placeholder": "log_level"
            }
          ]
        },
        {
          "id": "config-write",
          "method": "POST",
          "path": "/api/config/:name/write",
          "title": "写入配置",
          "description": "写入配置到指定文件",
          "pathParams": {
            "name": {
              "label": "配置名称",
              "placeholder": "bot"
            }
          },
          "bodyParams": [
            {
              "name": "data",
              "label": "配置数据",
              "type": "json",
              "required": true,
              "placeholder": "{\"log_level\": \"info\"}"
            },
            {
              "name": "path",
              "label": "配置路径",
              "type": "text",
              "placeholder": "log_level"
            },
            {
              "name": "backup",
              "label": "是否备份",
              "type": "select",
              "options": [
                { "value": "true", "label": "是" },
                { "value": "false", "label": "否" }
              ],
              "defaultValue": "true"
            }
          ]
        },
        {
          "id": "config-batch-set",
          "method": "POST",
          "path": "/api/config/:name/batch-set",
          "title": "批量设置",
          "description": "批量设置配置项（扁平化格式）",
          "pathParams": {
            "name": {
              "label": "配置名称",
              "placeholder": "bot"
            }
          },
          "bodyParams": [
            {
              "name": "flat",
              "label": "扁平化数据",
              "type": "json",
              "required": true,
              "placeholder": "{\"log_level\": \"info\"}"
            }
          ]
        }
      ]
    },
    {
      "id": "device",
      "title": "设备管理",
      "apis": [
        {
          "id": "device-register",
          "method": "POST",
          "path": "/api/device/register",
          "title": "注册设备",
          "description": "注册新的物联网设备到系统",
          "bodyParams": [
            {
              "name": "device_id",
              "label": "设备ID",
              "type": "text",
              "required": true,
              "placeholder": "DEVICE_001"
            },
            {
              "name": "device_type",
              "label": "设备类型",
              "type": "text",
              "required": true,
              "placeholder": "sensor"
            },
            {
              "name": "device_name",
              "label": "设备名称",
              "type": "text",
              "placeholder": "温度传感器"
            },
            {
              "name": "capabilities",
              "label": "设备能力",
              "type": "json",
              "placeholder": "[\"temperature\"]"
            }
          ]
        },
        {
          "id": "device-list",
          "method": "GET",
          "path": "/api/devices",
          "title": "设备列表",
          "description": "获取所有注册的物联网设备"
        },
        {
          "id": "device-detail",
          "method": "GET",
          "path": "/api/device/:deviceId",
          "title": "设备详情",
          "description": "获取指定设备的详细信息",
          "pathParams": {
            "deviceId": {
              "label": "设备ID",
              "placeholder": "DEVICE_001"
            }
          }
        },
        {
          "id": "device-ai",
          "method": "POST",
          "path": "/api/device/:deviceId/ai",
          "title": "设备AI回复",
          "description": "触发设备工作流，执行AI并驱动表情/TTS",
          "pathParams": {
            "deviceId": {
              "label": "设备ID",
              "placeholder": "webclient"
            }
          },
          "bodyParams": [
            {
              "name": "text",
              "label": "问题/文本",
              "type": "textarea",
              "required": true,
              "placeholder": "你好"
            },
            {
              "name": "workflow",
              "label": "工作流",
              "type": "text",
              "placeholder": "device",
              "defaultValue": "device"
            }
          ]
        }
      ]
    },
    {
      "id": "file",
      "title": "文件管理",
      "apis": [
        {
          "id": "file-upload",
          "method": "POST",
          "path": "/api/file/upload",
          "title": "上传文件",
          "description": "上传文件到服务器"
        },
        {
          "id": "file-get",
          "method": "GET",
          "path": "/api/file/:id",
          "title": "获取文件",
          "description": "通过文件ID获取文件内容",
          "pathParams": {
            "id": {
              "label": "文件ID",
              "placeholder": "file_id"
            }
          },
          "queryParams": [
            {
              "name": "download",
              "label": "下载模式",
              "type": "select",
              "options": [
                { "value": "false", "label": "预览" },
                { "value": "true", "label": "下载" }
              ],
              "defaultValue": "false"
            }
          ]
        },
        {
          "id": "file-delete",
          "method": "DELETE",
          "path": "/api/file/:id",
          "title": "删除文件",
          "description": "删除已上传的文件",
          "pathParams": {
            "id": {
              "label": "文件ID",
              "placeholder": "file_id"
            }
          }
        },
        {
          "id": "file-list",
          "method": "GET",
          "path": "/api/files",
          "title": "文件列表",
          "description": "获取所有已上传的文件列表"
        }
      ]
    },
    {
      "id": "plugin",
      "title": "插件管理",
      "apis": [
        {
          "id": "plugin-list",
          "method": "GET",
          "path": "/api/plugins",
          "title": "插件列表",
          "description": "获取所有已加载的插件信息"
        },
        {
          "id": "plugin-summary",
          "method": "GET",
          "path": "/api/plugins/summary",
          "title": "插件概览",
          "description": "单次返回插件列表及统计数据"
        },
        {
          "id": "plugin-reload",
          "method": "POST",
          "path": "/api/plugin/:key/reload",
          "title": "重载插件",
          "description": "重新加载指定插件",
          "pathParams": {
            "key": {
              "label": "插件标识",
              "placeholder": "example-plugin"
            }
          }
        },
        {
          "id": "plugin-tasks",
          "method": "GET",
          "path": "/api/plugins/tasks",
          "title": "定时任务",
          "description": "获取所有插件的定时任务列表"
        },
        {
          "id": "plugin-stats",
          "method": "GET",
          "path": "/api/plugins/stats",
          "title": "插件统计",
          "description": "获取插件统计数据"
        }
      ]
    },
    {
      "id": "mcp",
      "title": "MCP 服务",
      "apis": [
        {
          "id": "mcp-tools",
          "method": "GET",
          "path": "/api/mcp/tools",
          "title": "工具列表",
          "description": "获取所有 MCP 工具列表",
          "queryParams": [
            {
              "name": "stream",
              "label": "工作流过滤",
              "type": "text",
              "placeholder": "chat"
            }
          ]
        },
        {
          "id": "mcp-tools-streams",
          "method": "GET",
          "path": "/api/mcp/tools/streams",
          "title": "工具分组",
          "description": "按工作流分组获取工具列表"
        },
        {
          "id": "mcp-tools-call",
          "method": "POST",
          "path": "/api/mcp/tools/call",
          "title": "调用工具",
          "description": "调用指定的 MCP 工具",
          "bodyParams": [
            {
              "name": "name",
              "label": "工具名称",
              "type": "text",
              "required": true,
              "placeholder": "chat.screenshot"
            },
            {
              "name": "arguments",
              "label": "工具参数",
              "type": "json",
              "placeholder": "{}"
            }
          ]
        },
        {
          "id": "mcp-health",
          "method": "GET",
          "path": "/api/mcp/health",
          "title": "MCP 健康检查",
          "description": "检查 MCP 服务状态"
        }
      ]
    }
  ],
